---
import Layout from '~/layouts/PageLayout.astro'; // Or your standard AstroWind layout
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// 1. Automatically grab all images from the gallery directory at build time
const images = Object.values(
  import.meta.glob<{ default: ImageMetadata }>('../assets/images/gallery/*.{jpeg,jpg,png,webp}', { eager: true })
);

const metadata = {
  title: 'Images | North Sea Echoes',
  description: 'Promotional photos',
};
---

<!-- Original gallery display --><!-- <Layout metadata={metadata}>
  <section class="max-w-6xl mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">Images</h1>
      <p class="mt-4 text-lg text-neutral-400">Promotional photos.</p>
    </div>

    <div class="columns-1 sm:columns-2 md:columns-3 gap-4 space-y-4 [column-fill:_balance]">
      {
        images.map((img) => (
          <div class="break-inside-avoid overflow-hidden rounded-lg border border-neutral-800 bg-neutral-900/30 transition-all duration-300 hover:scale-[1.02] hover:border-neutral-700">
            <Image
              src={img.default}
              alt="North Sea Echoes promotional photo"
              width={800}
              widths={[400, 800]}
              sizes="(max-w-600px) 400px, 800px"
              class="w-full h-auto object-cover"
            />
          </div>
        ))
      }
    </div>
  </section>
</Layout> --><!-- New gallery layout -->
<Layout metadata={metadata}>
  <section class="max-w-6xl mx-auto px-4 py-12">
    <!-- Masonry Grid Container -->
    <div class="columns-1 sm:columns-2 md:columns-3 gap-4 space-y-4">
      {
        images.map((img, index) => (
          <div class="break-inside-avoid">
            {/* 1. Clickable Card triggers the dialog via inline JavaScript button behavior */}
            <button
              onclick={`document.getElementById('dialog-${index}').showModal()`}
              class="w-full text-left overflow-hidden rounded-lg border border-neutral-800 bg-neutral-900/30 transition-all duration-300 hover:scale-[1.01] hover:border-neutral-700 block"
            >
              <Image
                src={img.default}
                alt="North Sea Echoes promotional photo"
                width={600}
                class="w-full h-auto object-cover"
              />
            </button>

            {/* 2. Hidden Backdrop Dialog */}
            <dialog
              id={`dialog-${index}`}
              class="p-0 bg-transparent backdrop:bg-black/80 backdrop:backdrop-blur-sm max-w-[90vw] max-h-[90vh] rounded-lg overflow-hidden focus:outline-none"
              onclick="this.close()"
              {
              /* Clicking the backdrop closes it */ }
            >
              <form method="dialog" class="relative">
                {/* Close Button */}
                <button class="absolute top-4 right-4 z-50 bg-black/60 text-white hover:bg-black/90 w-10 h-10 rounded-full flex items-center justify-center text-xl font-bold transition">
                  ✕
                </button>
                {/* High-Res Render inside Modal */}
                <Image
                  src={img.default}
                  alt="Full screen view"
                  width={1400}
                  {
                  /* Higher resolution for full-screen display */ }
                  class="max-w-full max-h-[85vh] object-contain mx-auto"
                />
              </form>
            </dialog>
          </div>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  /* Clean animation override for opening the native dialog */
  dialog[open] {
    animation: fadeIn 0.25s ease-out;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>
